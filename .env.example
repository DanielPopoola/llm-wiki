# Oracle Database
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE=FREE
ORACLE_USER=llmwiki
ORACLE_PASSWORD=

# LLM Provider
LLM_PROVIDER=openai          # openai | anthropic | ollama
LLM_MODEL=qwen/qwen-32b
LLM_API_KEY=
LLM_BASE_URL=                # only needed for Ollama or custom endpoints

# Eval judge (separate from generation model)
JUDGE_MODEL=claude-sonnet-4-6
JUDGE_API_KEY=

# Embedding model (runs locally, no API key needed)
EMBED_MODEL=nomic-ai/nomic-embed-text-v2-moe

# Wiki settings
WIKIS_DIR=./wikis
